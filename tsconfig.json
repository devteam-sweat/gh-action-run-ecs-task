{
  "compilerOptions": {
    "target": "es6",
    "module": "es2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "./lib",
    "rootDir": "./src"
  },
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "vitest.config.ts"
  ]
}
